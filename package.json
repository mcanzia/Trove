{
  "name": "trove",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @trove/web dev",
    "dev:api": "pnpm --filter @trove/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter @trove/web lint"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
