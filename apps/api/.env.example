# Supabase — same project as the Trove frontend.
# The anon key is sufficient for read endpoints (RLS allows anon read on the
# tables Trove exposes). Use the service-role key only if you add write/admin
# endpoints, and never ship it to the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# HTTP
PORT=8787
# Comma-separated list of allowed CORS origins (the Trove dev + prod URLs).
CORS_ORIGINS=http://localhost:5173
