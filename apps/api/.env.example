# Supabase — same project as the Trove frontend.
# The anon key is used for read endpoints (RLS allows anon read).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — REQUIRED for the write endpoints (enrichment upsert/delete/
# score). It bypasses RLS, so never ship it to the browser. Get it from the
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — OPTIONAL. Enables the admin dashboard's live balance/budget panel
# (/api/ai-usage/openrouter). Held server-side only; never sent to the browser.
# Without it that panel shows "no live key" and the rest of the dashboard still
# works from persisted telemetry. OPENROUTER_DAILY_BUDGET_USD should match the
# pipeline's value so "budget remaining" lines up (default 2).
OPENROUTER_API_KEY=
OPENROUTER_DAILY_BUDGET_USD=2

# HTTP
PORT=8787
# Comma-separated list of allowed CORS origins (the Trove dev + prod URLs).
CORS_ORIGINS=http://localhost:5173
