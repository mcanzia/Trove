{
  "name": "@trove/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "API / service layer for Trove — Hono over Supabase.",
  "main": "./dist/index.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trove/shared": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "@supabase/supabase-js": "^2.106.1",
    "dotenv": "^16.4.7",
    "hono": "^4.7.10",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
  }
}
