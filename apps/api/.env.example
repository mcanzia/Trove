# Supabase — same project as the Trove frontend.
# The anon key is used for read endpoints (RLS allows anon read).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — REQUIRED for the write endpoints (enrichment upsert/delete/
# score). It bypasses RLS, so never ship it to the browser. Get it from the
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed to access the admin dashboard (/api/ai-usage/*).
# Fail-closed: unset = nobody is admin.
ADMIN_EMAILS=canziani.developer@gmail.com

# OpenRouter — OPTIONAL. Enables the admin dashboard's live balance/budget panel
# (/api/ai-usage/openrouter). Held server-side only; never sent to the browser.
# Without it that panel shows "no live key" and the rest of the dashboard still
# works from persisted telemetry. OPENROUTER_DAILY_BUDGET_USD should match the
# pipeline's value so "budget remaining" lines up (default 2).
OPENROUTER_API_KEY=
OPENROUTER_DAILY_BUDGET_USD=2

# Cloudflare — OPTIONAL. Enables the dashboard's live Workers AI neuron-usage
# panel (/api/ai-usage/cloudflare). The token needs **Account Analytics: Read**
# (the inference token used by the pipeline is NOT authorized for the analytics
# GraphQL API). Without these the panel shows "no live key".
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# HTTP
PORT=8787
# Comma-separated list of allowed CORS origins (the Trove dev + prod URLs).
CORS_ORIGINS=http://localhost:5173

# Gemini authoritative usage — OPTIONAL. Per-model RPD/RPM/TPM via Cloud Monitoring
# (the data behind AI Studio's Rate Limit dashboard). Needs a read-only SA with
# roles/monitoring.viewer on the AI Studio project. Because that free-tier project
# has billing off, set QUOTA_PROJECT to a billing-enabled project the SA can use
# (grant it roles/serviceusage.serviceUsageConsumer there). Provide the SA key as
# inline JSON (prod) or a file path (local dev).
GEMINI_MONITORING_PROJECT_ID=
GEMINI_MONITORING_SA_JSON=
# GEMINI_MONITORING_SA_KEYFILE=./gcp-monitoring-sa.json
GEMINI_MONITORING_QUOTA_PROJECT=
